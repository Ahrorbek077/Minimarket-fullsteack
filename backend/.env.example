# Django
DJANGO_SECRET_KEY=your-super-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# JWT
SIMPLE_JWT_SIGNING_KEY=your-jwt-signing-key-separate-from-secret-key

# Database (PostgreSQL)
DATABASE_URL=postgres://minimarket_user:minimarket_pass@localhost:5432/minimarket_db

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Media / Static
MEDIA_URL=/media/
STATIC_URL=/static/
